{
  "compilerOptions": {
    "ignoreDeprecations": "6.0",
    "typeRoots": ["./node_modules/@types"],
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "typeAcquisition": {
    "enable": false
  },
  "include": ["src", "vite.config.js"],
  "exclude": ["node_modules", "dist", "server", "electron"]
}
